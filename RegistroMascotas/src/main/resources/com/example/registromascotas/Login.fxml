<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="344.0" prefWidth="441.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.registromascotas.controller.LoginController">
   <children>
      <TextField fx:id="txtUsuario" layoutX="154.0" layoutY="44.0" promptText="Ingrese el Usuario" />
      <PasswordField fx:id="txtContrasena" layoutX="154.0" layoutY="145.0" promptText="Ingrese su contraseña" />
      <Button layoutX="101.0" layoutY="249.0" mnemonicParsing="false" onAction="#iniciarSesion" text="Ingresar" />
      <Button layoutX="241.0" layoutY="249.0" mnemonicParsing="false" text="Salir" />
      <Label layoutX="40.0" layoutY="50.0" text="Usuario" />
      <Label layoutX="40.0" layoutY="151.0" text="Contraseña" />
   </children>
</AnchorPane>
